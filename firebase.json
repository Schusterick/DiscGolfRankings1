{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "DiscGolfRankings/**",
      "DiscGolfRankings.xcodeproj/**",
      "**/*.swift",
      "**/*.plist",
      "**/*.entitlements",
      "**/*.xcodeproj",
      "**/*.xcassets/**"
    ],
    "headers": [
      {
        "source": "**/*.@(css|js)",
        "headers": [{"key": "Cache-Control", "value": "max-age=86400"}]
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint --if-present"
      ]
    }
  ]
}
