*.xcworkspace/contents.xcworkspacedata.lock

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# ─── Swift Package Manager ────────────────────────────────────────────────
.build/
Packages/
Package.pins
Package.resolved
.swiftpm/

# ─── CocoaPods (just in case) ─────────────────────────────────────────────
Pods/
*.xcworkspace

# ─── Fastlane (just in case) ──────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# ─── App secrets — never commit these ─────────────────────────────────────
# GoogleService-Info.plist is required for Firebase to work in dev,
# but should be reviewed before committing in production-grade repos.
# *.plist

# ─── Editor / OS noise ────────────────────────────────────────────────────
*.swp
*.swo
.idea/
.vscode/

# ─── Stray spreadsheets / unrelated docs ──────────────────────────────────
Cost_per_Disc_organized.xlsx
*.xlsx

# ─── Firebase service account keys (NEVER commit) ─────────────────────────
*firebase-adminsdk*.json
*service-account*.json

# ─── Node (Cloud Functions deps) ──────────────────────────────────────────
node_modules/

# ─── Firebase deploy/hosting cache ────────────────────────────────────────
.firebase/

# ─── Claude Code local tooling config ─────────────────────────────────────
.claude/

# ─── Local plist backups (never commit) ───────────────────────────────────
*.bak-schusterick
GoogleService-Info*.plist.bak*
